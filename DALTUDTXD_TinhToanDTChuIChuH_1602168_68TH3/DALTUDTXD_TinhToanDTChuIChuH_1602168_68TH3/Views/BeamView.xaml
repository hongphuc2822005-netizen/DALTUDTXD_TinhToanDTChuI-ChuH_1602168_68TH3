<Window x:Class="DALTUDTXD_TinhToanDTChuIChuH_1602168_68TH3.Views.BeamView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DALTUDTXD_TinhToanDTChuIChuH_1602168_68TH3.Views"
        xmlns:beamviewmodel="clr-namespace:DALTUDTXD_TinhToanDTChuIChuH_1602168_68TH3.ViewModels"
        mc:Ignorable="d"
               Title="Tính toán dầm thép" Height="600" Width="800">

    <Window.DataContext>
        <beamviewmodel:BeamViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= NHẬP ================= -->
        <StackPanel Orientation="Vertical" Margin="0,0,0,10">

            <!-- Dòng 1 -->
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="5">
                    <TextBlock Text="Chiều dài (m)" />
                    <TextBox Width="100" Text="{Binding Length, Mode=TwoWay}" />
                </StackPanel>

                
                <StackPanel Margin="5">
                    <TextBlock Text="Tải trọng (kN/m)" />
                    <TextBox Width="100" Text="{Binding Load, Mode=TwoWay}" />
                </StackPanel>

                
                <StackPanel Margin="5">
                    <TextBlock Text="(Không dùng) MomentLimit" />
                    <TextBox Width="100" Text="{Binding MomentLimit, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="Loại dầm" />
                    <ComboBox Width="120"
                              ItemsSource="{Binding BeamTypes}"
                              SelectedItem="{Binding SelectedBeamType}" />
                </StackPanel>
            </StackPanel>

            <!-- Dòng 2 -->
            <StackPanel Orientation="Horizontal">

                <StackPanel Margin="5">
                    <TextBlock Text="Chiều cao H (m)" />
                    <TextBox Width="100" Text="{Binding H, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="Bản cánh B (m)" />
                    <TextBox Width="100" Text="{Binding B, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="tf (m)" />
                    <TextBox Width="100" Text="{Binding tf, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Margin="5">
                    <TextBlock Text="tw (m)" />
                    <TextBox Width="100" Text="{Binding tw, Mode=TwoWay}" />
                </StackPanel>

                <Button Content="Thêm Dầm"
                        Width="100"
                        Margin="10,20,0,0"
                        Command="{Binding AddBeamCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- ================= BẢNG ================= -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Beams}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0,0,0,10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Loại" Binding="{Binding BeamType}" />
                <DataGridTextColumn Header="L (m)" Binding="{Binding Length}" />
                <DataGridTextColumn Header="q (kN/m)" Binding="{Binding Load}" />

                <DataGridTextColumn Header="M (kNm)" Binding="{Binding CalculatedMoment, StringFormat=N2}" />
                <DataGridTextColumn Header="W (m³)" Binding="{Binding SectionModulus, StringFormat=E2}" />
                <DataGridTextColumn Header="σ (MPa)" Binding="{Binding Stress, StringFormat=N2}" />

                <DataGridCheckBoxColumn Header="An toàn" Binding="{Binding IsSafe}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- ================= EXPORT ================= -->
        <Button Grid.Row="2"
                Content="Xuất Excel"
                Width="120"
                Height="30"
                HorizontalAlignment="Right"
                Command="{Binding ExportToExcelCommand}" />
    </Grid>
</Window>
